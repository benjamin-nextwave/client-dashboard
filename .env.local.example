# Supabase Configuration
# Copy this file to .env.local and fill in your values

# Project URL - Supabase Dashboard -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Anon/Public Key - Supabase Dashboard -> Project Settings -> API -> anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key (SECRET - never expose to browser)
# Supabase Dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Lead Inbox — Make.com webhook voor outbound replies (server-only)
# Dashboard POST't hier de reply-payload heen; Make handelt de
# Instantly-call af. NIET met NEXT_PUBLIC_ prefix — moet niet in browser.
MAKE_OUTBOUND_WEBHOOK_URL=
